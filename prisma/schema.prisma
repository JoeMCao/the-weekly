// Weekly Compass — Prisma schema
// Single-user weekly review. One row per week.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeeklyReview {
  id                   String   @id @default(cuid())
  weekStart            DateTime @unique @db.Date
  principles           Json     @default("[]")
  weeklyReflection     Json     @default("{\"weekSummary\":\"\",\"wins\":\"\",\"attentionRequired\":\"\",\"recurringPattern\":\"\",\"theme\":\"\",\"nextWeekCommitments\":[\"\",\"\",\"\",\"\",\"\"]}")
  reviewMetadata       Json     @default("{\"reviewDate\":\"\",\"context\":\"\",\"savedAt\":null}")
  priorWeekCommitments Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
