// Weekly Compass — Prisma schema
// Single-user weekly review. One row per week (Sunday week start).
// Nested sections stored as JSON for simplicity.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeeklyReview {
  id              String   @id @default(cuid())
  weekStart       DateTime @unique @db.Date
  alignmentScore  Int?
  alignmentReason String?
  principles      Json     @default("[]")
  faults          Json     @default("{\"selected\":[],\"whereShowedUp\":\"\"}")
  provedMeWrong   String?
  avoiding        String?
  commitments     Json     @default("[\"\",\"\",\"\"]")
  nextWeekJose    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
